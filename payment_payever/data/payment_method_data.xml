    <!-- ═══════════════════════════════════════════════════════
         Core payever payment methods
         These records are created once on install (noupdate=1)
         and are then linked to payever providers via post_init_hook.
    ═══════════════════════════════════════════════════════ -->

    <record id="payment_method_paypal" model="payment.method">
